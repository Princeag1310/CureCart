# ==========================================
# 🚀 CURECART ENVIRONMENT VARIABLES 🚀
# ==========================================
# Instructions: Copy this file, rename it to ".env", and fill in your keys.

# ------------------------------------------
# 1. DATABASE (Aiven PostgreSQL)
# ------------------------------------------
DATABASE_URL="postgresql://YOUR_AIVEN_USER:YOUR_AIVEN_PASSWORD@YOUR_AIVEN_HOST:PORT/defaultdb?sslmode=require"

# ------------------------------------------
# 2. GOOGLE GEMINI AI (Medical Assistant)
# ------------------------------------------
GEMINI_API_KEY="your_gemini_api_key_here"

# ------------------------------------------
# 3. IMAGEKIT (Prescription Uploads)
# ------------------------------------------
IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/your_id"
IMAGEKIT_PUBLIC_KEY="your_public_key"
IMAGEKIT_PRIVATE_KEY="your_private_key"

# ------------------------------------------
# 4. NEXT AUTH (Google Login)
# ------------------------------------------
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
NEXTAUTH_SECRET="any_random_long_string_for_encryption"
NEXTAUTH_URL="http://localhost:3000"

# ------------------------------------------
# 5. RAZORPAY (Payments Checkout)
# ------------------------------------------
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_key_secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_your_key_id"

# ------------------------------------------
# 6. ARCJET (Bot & Security Protection)
# ------------------------------------------
ARCJET_KEY="ajkey_your_arcjet_key"

# ------------------------------------------
# 7. MAILERPRO MICROSERVICE (Optional)
# ------------------------------------------
MAILER_PRO_API_URL="http://localhost:5000/api/contacts"
